{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"description": "GitHub Actions secrets for jjheffernan/animalgaragenet. Values live in GitHub Settings → Secrets — never commit.",
	"groups": {
		"deploy": {
			"description": "Required for org mirror → Netlify deploy",
			"required": true,
			"secrets": [
				{
					"name": "ORG_REPO_DEPLOY_KEY",
					"workflows": ["sync-org-main.yml"]
				}
			]
		},
		"supabase": {
			"description": "Auth + Postgres (readiness probes + local parity with Netlify integration)",
			"required": false,
			"secrets": [
				{
					"name": "SUPABASE_DATABASE_URL",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "SUPABASE_ANON_KEY",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "SUPABASE_SERVICE_ROLE_KEY",
					"workflows": ["readiness-ci.yml"]
				}
			]
		},
		"saleor": {
			"description": "Headless commerce smoke + readiness",
			"required": false,
			"secrets": [
				{
					"name": "PUBLIC_SALEOR_API_URL",
					"workflows": ["ci.yml", "readiness-ci.yml"]
				},
				{
					"name": "SALEOR_CHANNEL",
					"workflows": ["ci.yml", "readiness-ci.yml"]
				}
			]
		},
		"ghost": {
			"description": "Guides + blog CMS",
			"required": false,
			"secrets": [
				{
					"name": "GHOST_URL",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "GHOST_CONTENT_API_KEY",
					"workflows": ["readiness-ci.yml"]
				}
			]
		},
		"youtube": {
			"description": "Watch hub sync probe",
			"required": false,
			"secrets": [
				{
					"name": "YOUTUBE_API_KEY",
					"workflows": ["readiness-ci.yml"]
				}
			]
		},
		"cdn": {
			"description": "CDN + S3 upload readiness",
			"required": false,
			"secrets": [
				{
					"name": "PUBLIC_CDN_BASE_URL",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "S3_BUCKET",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "S3_REGION",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "AWS_ACCESS_KEY_ID",
					"workflows": ["readiness-ci.yml"]
				},
				{
					"name": "AWS_SECRET_ACCESS_KEY",
					"workflows": ["readiness-ci.yml"]
				}
			]
		}
	},
	"netlify_only": [
		"PUBLIC_SITE_URL",
		"PUBLIC_DEFAULT_LOCALE",
		"PUBLIC_DEFAULT_CURRENCY",
		"SALEOR_WEBHOOK_SECRET",
		"YOUTUBE_SYNC_SECRET",
		"AWS_CLOUDFRONT_DISTRIBUTION_ID",
		"SITE_LOCKED",
		"BUG_REPORT_WEBHOOK_URL",
		"SUPABASE_JWT_SECRET"
	],
	"never_commit": ["DEV_ADMIN", "LOCAL_DEV_AUTH", ".env", "supabase/.temp", "supabase/.branches"]
}

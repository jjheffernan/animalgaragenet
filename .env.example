# Supabase (auth, content metadata, newsletter)
# Netlify Supabase integration sets these automatically — do not duplicate as PUBLIC_* vars.
# SUPABASE_DATABASE_URL is the Postgres connection string; the app derives the REST API URL from it.
SUPABASE_DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional — not used by app code today; available for custom JWT verification if needed
# SUPABASE_JWT_SECRET=your-jwt-secret

# Local dev with `supabase start`: set PUBLIC_SUPABASE_URL when DATABASE_URL has no project ref
# (e.g. postgresql://postgres:postgres@127.0.0.1:54322/postgres → API at http://127.0.0.1:54321)
# PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

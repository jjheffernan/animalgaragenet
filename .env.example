# Supabase (auth, content metadata, newsletter)
# Netlify Supabase integration sets these automatically — do not duplicate as PUBLIC_* vars.
# SUPABASE_DATABASE_URL is the Postgres connection string; the app derives the REST API URL from it.
SUPABASE_DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional — not used by app code today; available for custom JWT verification if needed
# SUPABASE_JWT_SECRET=your-jwt-secret

# Local dev with `supabase start`: set PUBLIC_SUPABASE_URL when DATABASE_URL has no project ref
# (e.g. postgresql://postgres:postgres@127.0.0.1:54322/postgres → API at http://127.0.0.1:54321)
# PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Dev: bypass admin role check on localhost only (never Netlify/production)
# DEV_ADMIN=true

# Dev: quick-login buttons on /auth/sign-in (localhost only, never Netlify)
# LOCAL_DEV_AUTH=true

# Saleor headless commerce (backend on separate domain)
PUBLIC_SALEOR_API_URL=https://<your-saleor-host>/graphql/
# server-only — channel slug; must match Saleor Dashboard channel with payment app enabled
SALEOR_CHANNEL=default-channel
# server-only — JSON locale→channel slug map overriding defaults in channels.ts (e.g. {"de-DE":"eu"})
# SALEOR_LOCALE_CHANNELS={"en-US":"us","en-GB":"eu","ja-JP":"jp"}
# server-only — JSON channel slug→free-shipping subtotal threshold (e.g. {"us":75,"eu":100,"jp":10000})
# SALEOR_FREE_SHIPPING_THRESHOLDS={"us":75,"eu":100,"jp":10000}
# server-only — optional bearer for privileged Saleor mutations (if your instance requires app auth)
# SALEOR_APP_TOKEN=
# server-only — verify Saleor-Signature on POST /api/webhooks/saleor (ORDER_CREATED, etc.)
# SALEOR_WEBHOOK_SECRET=
# Payment provider secret keys (Stripe secret, Adyen HMAC) belong in Saleor Dashboard Payment App config — NOT here.
# Stripe publishable key is returned at runtime via paymentGatewayInitialize — do not add STRIPE_* to storefront env.

# CDN / media delivery
PUBLIC_CDN_BASE_URL=https://<your-cdn-host>

# S3 origin (behind CloudFront)
S3_BUCKET=your-media-bucket
S3_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# Site lockdown (production preview) — redirect public traffic to /locked; admins pass through
# SITE_LOCKED=true

# Site
PUBLIC_SITE_URL=https://<your-site-host>
PUBLIC_DEFAULT_LOCALE=en-US
PUBLIC_DEFAULT_CURRENCY=USD

# Client analytics — optional script URL (Plausible, Umami, self-hosted, etc.)
# PUBLIC_ANALYTICS_SCRIPT_URL=https://analytics.example.com/script.js

# Ghost CMS (guides + blog — server-only)
# Content API: Ghost Admin → Settings → Integrations → Add custom integration
GHOST_URL=https://<your-ghost-host>
GHOST_CONTENT_API_KEY=your-content-api-key

# YouTube admin sync (server-only)
YOUTUBE_API_KEY=your-youtube-data-api-key
YOUTUBE_SYNC_SECRET=your-cron-webhook-bearer-token

# Account social linking OAuth (server-only — mock handle flow when unset)
# SOCIAL_INSTAGRAM_CLIENT_ID=
# SOCIAL_YOUTUBE_CLIENT_ID=
# SOCIAL_TIKTOK_CLIENT_KEY=
# SOCIAL_DISCORD_CLIENT_ID=

# Support bug reports — optional webhook for staff email/Slack (POST JSON on new report)
# BUG_REPORT_WEBHOOK_URL=

# OpenTelemetry / LGTM (optional — see docs/infrastructure/observability-lgtm.md)
# OTLP traces → Grafana Tempo when SDK is wired; hook point reads these today.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=animalgarage-storefront
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1

# GitHub Actions only (never Netlify) — org mirror deploy key; see scripts/setup-org-sync-auth.sh
# ORG_REPO_DEPLOY_KEY=

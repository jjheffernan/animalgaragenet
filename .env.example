# Supabase (auth, content metadata, newsletter)
# Get these from: Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dev: bypass admin role check (optional)
# DEV_ADMIN=true

# Saleor headless commerce (backend on separate domain)
PUBLIC_SALEOR_API_URL=https://commerce.animalgarage.net/graphql/
SALEOR_CHANNEL=default-channel

# CDN / media delivery
PUBLIC_CDN_BASE_URL=https://cdn.animalgarage.net

# S3 origin (behind CloudFront)
S3_BUCKET=animalgarage-media
S3_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Site
PUBLIC_SITE_URL=https://animalgarage.net
PUBLIC_DEFAULT_LOCALE=en-US
PUBLIC_DEFAULT_CURRENCY=USD

# Ghost CMS (guides + blog — server-only)
# Content API: Ghost Admin → Settings → Integrations → Add custom integration
GHOST_URL=https://content.animalgarage.net
GHOST_CONTENT_API_KEY=your-content-api-key

# YouTube admin sync (server-only)
YOUTUBE_API_KEY=your-youtube-data-api-key
YOUTUBE_SYNC_SECRET=your-cron-webhook-bearer-token

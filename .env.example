# Supabase (auth, content metadata, newsletter)
# Get these from: Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dev: bypass admin role check on localhost only (never Netlify/production)
# DEV_ADMIN=true

# Dev: quick-login buttons on /auth/sign-in (localhost only, never Netlify)
# LOCAL_DEV_AUTH=true

# Saleor headless commerce (backend on separate domain)
PUBLIC_SALEOR_API_URL=https://<your-saleor-host>/graphql/
# server-only — channel slug; must match Saleor Dashboard channel with payment app enabled
SALEOR_CHANNEL=default-channel
# server-only — optional bearer for privileged Saleor mutations (if your instance requires app auth)
# SALEOR_APP_TOKEN=
# server-only — verify Saleor-Signature on POST /api/webhooks/saleor (ORDER_CREATED, etc.)
# SALEOR_WEBHOOK_SECRET=
# Payment provider secret keys (Stripe secret, Adyen HMAC) belong in Saleor Dashboard Payment App config — NOT here.
# Stripe publishable key is returned at runtime via paymentGatewayInitialize — do not add STRIPE_* to storefront env.

# CDN / media delivery
PUBLIC_CDN_BASE_URL=https://cdn.animalgarage.net

# S3 origin (behind CloudFront)
S3_BUCKET=animalgarage-media
S3_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Site lockdown (production preview) — redirect public traffic to /locked; admins pass through
# SITE_LOCKED=true

# Site
PUBLIC_SITE_URL=https://animalgarage.net
PUBLIC_DEFAULT_LOCALE=en-US
PUBLIC_DEFAULT_CURRENCY=USD

# Ghost CMS (guides + blog — server-only)
# Content API: Ghost Admin → Settings → Integrations → Add custom integration
GHOST_URL=https://content.animalgarage.net
GHOST_CONTENT_API_KEY=your-content-api-key

# YouTube admin sync (server-only)
YOUTUBE_API_KEY=your-youtube-data-api-key
YOUTUBE_SYNC_SECRET=your-cron-webhook-bearer-token
